{
    "name": "dash-mcp-server",
    "version": "1.1.0",
    "description": "MCP server for Dash, the macOS documentation browser",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "dash-mcp-server": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "cheerio": "^1.0.0",
        "turndown": "^7.2.0",
        "zod": "^3.24.4"
    },
    "devDependencies": {
        "@types/node": "^22.15.21",
        "@types/turndown": "^5.0.5",
        "typescript": "^5.8.3",
        "vitest": "^3.2.1"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
